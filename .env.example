# ─── Kafka ───────────────────────────────────────────────────────────────────
# Digunakan oleh docker-compose; jangan diubah kecuali ada port conflict
KAFKA_BROKERS=kafka:9094

# ─── Transaction Generator ────────────────────────────────────────────────────
# Jumlah event klaim yang dikirim per detik (angka bulat, min 1)
EVENTS_PER_SECOND=2

# Proporsi event yang dibuat anomali (0.0 – 1.0)
# 0.12 berarti ~12% event akan memicu setidaknya satu aturan fraud
ANOMALY_RATIO=0.12

# ─── Port Mapping ─────────────────────────────────────────────────────────────
KAFKA_UI_PORT=8080
BACKEND_PORT=3001
FRONTEND_PORT=5173
